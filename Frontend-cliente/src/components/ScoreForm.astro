---
// src/components/ScoreForm.astro

interface Props {
  songId: string
  userId: string
}

const { songId, userId } = Astro.props
---

<form
  id="vote-form"
  aria-label="Formulario de votación"
  class="flex flex-col w-full items-center justify-between pl-5 gap-4 border-t border-dim pt-4 md:border-l-2 md:border-t-0 md:items-end md:w-[50%] "
>
  <!-- Campos ocultos que el backend necesita -->
  <input type="hidden" name="songId" value={songId} />
  <input type="hidden" name="userId" value={userId} />

  <fieldset class="border-none p-0 m-0">
    <legend class="font-vt text-[0.8rem] tracking-[3px] text-dim mb-3 text-center md:text-right">
      // TU PUNTUACIÓN
    </legend>

    <div class="flex items-center gap-4">
      <button
        type="button"
        id="btn-minus"
        aria-label="Reducir puntuación"
        class="w-9 h-9 bg-deep border border-dim text-white font-vt text-xl
               flex items-center justify-center
               hover:border-cyan hover:text-cyan transition-all cursor-pointer"
      >
        −
      </button>

      <div class="relative">
        <input
          type="number"
          id="score"
          name="score"
          min="0"
          max="10"
          step="0.1"
          value="5.0"
          aria-live="polite"
          aria-label="Puntuación actual"
          class="font-vt text-[3rem] leading-none text-yellow glow-yellow
                 w-22.5 text-center bg-transparent border-b border-dim
                 focus:border-cyan focus:outline-none
                 [appearance:textfield]
                 [&::-webkit-outer-spin-button]:appearance-none
                 [&::-webkit-inner-spin-button]:appearance-none"
        />
        <span
          class="font-vt text-[1rem] text-dim bottom-2"
          aria-hidden="true"
        >
          /10
        </span>
      </div>

      <button
        type="button"
        id="btn-plus"
        aria-label="Aumentar puntuación"
        class="w-9 h-9 bg-deep border border-dim text-white font-vt text-xl
               flex items-center justify-center
               hover:border-cyan hover:text-cyan transition-all cursor-pointer"
      >
        +
      </button>
    </div>

    <!-- Mensaje de validación -->
    <p
      id="score-error"
      role="alert"
      aria-live="assertive"
      class="font-vt text-[0.8rem] tracking-[2px] text-pink mt-2 hidden"
    >
    </p>
  </fieldset>

  <button
    id="vote-btn"
    type="submit"
    class="w-full mt-4.5 py-3.25 bg-transparent border border-pink text-pink font-vt text-[1.2rem] tracking-[6px] cursor-pointer relative overflow-hidden transition-colors hover:bg-[#ff2d78] glow-pink"
  >
    [ ENVIAR VOTO ]
  </button>

  <!-- Estado del envío -->
  <p
    id="vote-status"
    aria-live="polite"
    class="font-vt text-[0.8rem] tracking-[3px] text-center hidden"
  >
  </p>
</form>

<script>
  const input     = document.getElementById('score')        as HTMLInputElement
  const btnMinus  = document.getElementById('btn-minus')    as HTMLButtonElement
  const btnPlus   = document.getElementById('btn-plus')     as HTMLButtonElement
  const form      = document.getElementById('vote-form')    as HTMLFormElement
  const errorMsg  = document.getElementById('score-error')  as HTMLParagraphElement
  const statusMsg = document.getElementById('vote-status')  as HTMLParagraphElement
  const voteBtn   = document.getElementById('vote-btn')     as HTMLButtonElement

  const STEP = 0.1
  const MIN  = 0
  const MAX  = 10

  // ── Helpers ──────────────────────────────────────────
  function round(val: number): number {
    return Math.round(val * 10) / 10
  }

  function setScore(val: number) {
    const clamped = Math.min(MAX, Math.max(MIN, round(val)))
    input.value = clamped.toFixed(1)
    clearError()
  }

  function showError(msg: string) {
    errorMsg.textContent = msg
    errorMsg.classList.remove('hidden')
    input.classList.add('border-pink')
    input.classList.remove('border-dim')
  }

  function clearError() {
    errorMsg.classList.add('hidden')
    input.classList.remove('border-pink')
    input.classList.add('border-dim')
  }

  function validate(): boolean {
    const val = parseFloat(input.value)

    if (isNaN(val)) {
      showError('// ingresa un número válido')
      return false
    }
    if (val < MIN || val > MAX) {
      showError(`// el valor debe estar entre ${MIN} y ${MAX}`)
      return false
    }
    return true
  }

  // ── Botones +/- ───────────────────────────────────────
  btnMinus.addEventListener('click', () => {
    setScore(parseFloat(input.value) - STEP)
  })

  btnPlus.addEventListener('click', () => {
    setScore(parseFloat(input.value) + STEP)
  })

  // ── Escritura directa ─────────────────────────────────
  input.addEventListener('blur', () => {
    if (!validate()) return
    setScore(parseFloat(input.value))
  })

  // Evita que se pase del rango mientras escribe
  input.addEventListener('input', () => {
    const val = parseFloat(input.value)
    if (!isNaN(val) && val > MAX) input.value = MAX.toFixed(1)
    if (!isNaN(val) && val < MIN) input.value = MIN.toFixed(1)
  })

  // ── Submit ────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!validate()) return

    const payload = {
      songId: (form.querySelector('[name="songId"]') as HTMLInputElement).value,
      userId: (form.querySelector('[name="userId"]') as HTMLInputElement).value,
      score:  parseFloat(input.value),
    }

    // Estado de carga
    voteBtn.disabled = true
    voteBtn.textContent = '[ ENVIANDO... ]'
    statusMsg.classList.remove('hidden', 'text-cyan', 'text-pink')
    statusMsg.classList.add('text-dim')
    statusMsg.textContent = '// procesando voto...'

    try {
      // TODO: reemplazar la URL cuando el backend esté listo
      const res = await fetch('/api/votes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })

      if (!res.ok) throw new Error(`Error ${res.status}`)

      // Éxito
      voteBtn.textContent = '[ ✓ VOTO REGISTRADO ]'
      voteBtn.classList.remove('border-pink', 'text-pink', 'glow-pink')
      voteBtn.classList.add('border-cyan', 'text-cyan', 'glow-cyan')
      statusMsg.classList.replace('text-dim', 'text-cyan')
      statusMsg.textContent = '// voto guardado correctamente'

    } catch (err) {
      // Error
      voteBtn.disabled = false
      voteBtn.textContent = '[ ENVIAR VOTO ]'
      statusMsg.classList.replace('text-dim', 'text-pink')
      statusMsg.textContent = '// error al enviar, intenta de nuevo'
      console.error('Vote error:', err)
    }
  })
</script>