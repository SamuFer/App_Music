---
import Layout from "../layouts/Layout-login.astro"
import '../styles/global.css';
import LoginForm from '../components/LoginForm'
import SpotifyLoginBtn from '../components/SpotifyLoginBtn'
---

<Layout title="Iniciar sesión">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md flex flex-col gap-6">

      <!-- Header -->
      <div class="text-center">
        <h1 class="text-3xl font-display font-bold text-white">Bienvenido</h1>
        <p class="text-gray-400 mt-2">Iniciá sesión para continuar</p>
      </div>

      <!-- Spotify -->
      <SpotifyLoginBtn client:load />

      <!-- Divisor -->
      <div class="flex items-center gap-4">
        <div class="flex-1 h-px bg-white/10"></div>
        <span class="text-gray-500 text-sm">o continuá con email</span>
        <div class="flex-1 h-px bg-white/10"></div>
      </div>

      <!-- Formulario email/password -->
      <LoginForm client:load />

      <!-- Registro -->
      <p class="text-center text-gray-500 text-sm">
        ¿Eres un usuario nuevo?
        <a href="/register" class="text-white hover:underline ml-1">
          Registrate
        </a>
      </p>

    </div>
  </main>
</Layout>