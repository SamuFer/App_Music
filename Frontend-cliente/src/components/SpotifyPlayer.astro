---
// src/components/SpotifyPlayer.astro
interface Props {
  trackId: string
  trackTitle: string
}
const { trackId, trackTitle } = Astro.props

const embedUrl = `https://open.spotify.com/embed/track/${trackId}?utm_source=generator`
---

<iframe
  src={`${embedUrl}&theme=0`}
  title={`Reproductor de Spotify: ${trackTitle}`}
  width="100%"
  height="80"
  frameborder="0"
  allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
  loading="lazy"
></iframe>

